{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/api/v1/(.*)",
      "dest": "https://uni-resource-hub-18s1.vercel.app/api/v1"
    },
    {
      "src": "/(.*)",
      "dest": "/",
      "status": 200
    }
  ]
}