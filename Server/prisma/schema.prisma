generator client {
  provider        = "prisma-client-js"
  output          = "../generated/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
  extensions   = [vector]
}

model User {
  id             Int            @id @default(autoincrement())
  username       String
  email          String         @unique
  password       String
  createdAt      DateTime       @default(now())
  userActivities userActivity[]
  Resource       Resource[]
}

model Department {
  id        Int                    @id @default(autoincrement())
  name      String                 @unique
  createdAt DateTime               @default(now())
  tags      String[]               @default([])
  embedding Unsupported("vector")?
  semesters Semester[]
  resources Resource[]
  courses   Course[]

  @@index([embedding], map: "department_embedding_hnsw_idx")
}

model Semester {
  id           Int        @id @default(autoincrement())
  departmentId Int
  createdAt    DateTime   @default(now())
  Number       Int
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  courses      Course[]
}

model Course {
  id           Int        @id @default(autoincrement())
  name         String
  semesterId   Int
  createdAt    DateTime   @default(now())
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  semester     Semester   @relation(fields: [semesterId], references: [id], onDelete: Cascade)
}

model Resource {
  id             Int                    @id @default(autoincrement())
  name           String
  File           String?
  image          String?
  createdAt      DateTime               @default(now())
  publishStatus  PublishStatus          @default(WAITING_FOR_APPROVAL)
  departmentId   Int
  tags           String[]               @default([])
  userId         Int
  embedding      Unsupported("vector")?
  userActivities userActivity[]
  department     Department             @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([embedding], map: "resource_embedding_hnsw_idx")
}

model BlackListedToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  createdAt DateTime @default(now())
}

model userActivity {
  id         Int          @id @default(autoincrement())
  type       ActivityType
  userId     Int
  resourceId Int
  createdAt  DateTime     @default(now())
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource   Resource     @relation(fields: [resourceId], references: [id], onDelete: Cascade)
}

enum PublishStatus {
  PUBLISHED
  WAITING_FOR_APPROVAL
  REJECTED
}

enum ActivityType {
  DOWNLOAD
  UPLOAD
  SAVE
}
